<h1>Таблица мотивации</h1>

<div style="margin-bottom: 20px;">
  <%= link_to "← Вернуться в Личный кабинет", dashboard_path, data: { turbo: false }, style: "text-decoration: none; color: #0056b3;" %>
</div>

<table border="1" cellpadding="10" style="width: 100%; border-collapse: collapse; background: white; text-align: center;">
  <thead>
    <tr style="background: #f1f3f5;">
      <th>Категория / Актер</th>
      <% @actors.each do |actor| %>
        <th><%= actor.name %></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <tr style="background: #f8d7da; font-weight: bold;">
      <td colspan="<%= @actors.count + 1 %>" style="text-align: left;">МИНУС</td>
    </tr>
    <% categories_minus = [
      ['dirty', 'Грязно'], ['no_report', 'Нет отчета'], ['report_error', 'Ошибка в отчете'], 
      ['no_upsell', 'Не сделал допродажу'], ['late_15', 'Опоздание (15 мин)'], 
      ['late_game', 'Опоздание (задержка игры)'], ['light_on', 'Не выкл свет/технику'], 
      ['no_consumables', 'Нет расходников'], ['no_breakage_report', 'Не сообщил о поломке'], 
      ['skip_warned', 'Прогул с предупреждением'], ['dislike', 'Дизлайк от админа']
    ] %>
    <% categories_minus.each do |cat_key, cat_name| %>
      <tr>
        <td style="text-align: left;"><%= cat_name %></td>
        <% @actors.each do |actor| %>
          <td style="color: red;">
            <%= actor.actor_transactions.where(category: cat_key, transaction_type: 'minus').sum(:amount).to_i %>
          </td>
        <% end %>
      </tr>
    <% end %>

    <tr style="background: #d4edda; font-weight: bold;">
      <td colspan="<%= @actors.count + 1 %>" style="text-align: left;">ПЛЮС</td>
    </tr>
    <% categories_plus = [
      ['repair', 'Ремонт'], ['replacement', 'Замена'], ['review_aggr', 'Отзыв Агрегатор'], 
      ['review_yandex', 'Отзыв Яндекс'], ['upsell', 'Допродажа'], 
      ['photo', 'Фото'], ['initiative', 'Инициатива'], ['like', 'Лайк от админа']
    ] %>
    <% categories_plus.each do |cat_key, cat_name| %>
      <tr>
        <td style="text-align: left;"><%= cat_name %></td>
        <% @actors.each do |actor| %>
          <td style="color: green;">
            <%= actor.actor_transactions.where(category: cat_key, transaction_type: 'plus').sum(:amount).to_i %>
          </td>
        <% end %>
      </tr>
    <% end %>

    <tr style="background: #e9ecef; font-weight: bold; font-size: 1.2em;">
      <td style="text-align: left;">ИТОГО (Премия)</td>
      <% @actors.each do |actor| %>
        <% total = actor.actor_transactions.sum(:amount).to_i %>
        <td style="color: <%= total >= 0 ? 'green' : 'red' %>;"><%= total %></td>
      <% end %>
    </tr>
  </tbody>
</table>

<% if current_user.admin? %>
  <div style="margin-top: 30px; padding: 20px; background: #f9f9f9; border: 1px dashed #666; border-radius: 8px;">
    <h3>Добавить запись вручную (Админ)</h3>
    <%= form_with model: ActorTransaction.new, local: true do |f| %>
      <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;">
        <div>
          <%= f.label :user_id, "Актер" %><br>
          <%= f.collection_select :user_id, @actors, :id, :name, {}, style: "padding: 8px;" %>
        </div>
        <div>
          <%= f.label :transaction_type, "Тип" %><br>
          <%= f.select :transaction_type, [['Плюс', 'plus'], ['Минус', 'minus']], {}, style: "padding: 8px;" %>
        </div>
        <div>
          <%= f.label :category, "Категория" %><br>
          <%= f.select :category, (categories_minus + categories_plus).map { |k, v| [v, k] }, {}, style: "padding: 8px;" %>
        </div>
        <div>
          <%= f.label :amount, "Сумма (необяз.)" %><br>
          <%= f.number_field :amount, style: "padding: 8px; width: 100px;" %>
        </div>
        <%= f.submit "Добавить", style: "padding: 9px 20px; background: #2c3e50; color: white; border: none; border-radius: 4px; cursor: pointer;" %>
      </div>
    <% end %>
  </div>
<% end %>