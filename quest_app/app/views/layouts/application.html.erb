<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Wonderland | Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="QuestApp">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link href="https://fonts.googleapis.com/css2?family=Nosifer&family=Oswald:wght@300;400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="horror-theme">
    <div class="noise-overlay"></div>
    
    <nav class="navbar navbar-expand-lg border-bottom mb-4 custom-navbar">
      <div class="container">
        <%= link_to "WONDERLAND", dashboard_path, class: "navbar-brand font-horror tracking-widest text-blood" %>
        
        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <% if logged_in? %>
              <li class="nav-item">
                <span class="nav-link text-gray me-3">Привет, <strong class="text-wonderTeal"><%= current_user.name %></strong>!</span>
              </li>
              <li class="nav-item">
                <%= link_to "Личный кабинет", dashboard_path, class: "nav-link text-wonderYellow hover-teal" %>
              </li>
              <li class="nav-item ms-3">
                <%= button_to "Выйти", logout_path, method: :delete, class: "btn btn-outline-blood btn-sm uppercase tracking-wider" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Вход", login_path, class: "nav-link hover-teal" %>
              </li>
              <li class="nav-item ms-2">
                <%= link_to "Регистрация", signup_path, class: "btn btn-blood btn-sm uppercase tracking-wider" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container main-container position-relative z-10">
      <% if notice %>
        <div class="alert custom-alert-success alert-dismissible fade show shadow-glow" role="alert">
          <%= notice %>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="alert custom-alert-danger alert-dismissible fade show shadow-glow-blood" role="alert">
          <%= alert %>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>